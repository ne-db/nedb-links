# NEDB Links — configuration
# Copy to .env and adjust. Real environment variables always win.

# API server port (Express: API + public profiles + editor SPA in production).
# LINKS_API_PORT is canonical; generic PORT works as a fallback but is also
# read by other tools (Vite, PaaS runtimes) — collisions and dev-proxy skew
# follow. The Vite dev proxy resolves the SAME chain, so changing this in
# .env moves both sides together, and the dev-api wrapper restarts the API
# on .env edits so it never lags a Vite env-triggered restart.
LINKS_API_PORT=3001

# Vite dev client port (browser target during `npm run dev`)
VITE_PORT=3000

# Running nedbd instance — ALL state lives there. No other database exists.
NEDB_URL=http://127.0.0.1:7070

# Database name inside nedbd
NEDB_DB=links

# Bearer token, when nedbd runs token-gated (NEDBD_TOKEN on the daemon)
# NEDB_TOKEN=

# v0.1 single-owner auth: token gating the editor and every write.
# REQUIRED before exposing an instance publicly.
# LINKS_ADMIN_TOKEN=

# Public origin used in share URLs and QR payloads (set in production)
# PUBLIC_ORIGIN=https://links.example.com

# AI Profile Assistant (optional) — AiAS gateway credentials.
# The assistant is gracefully absent when unset.
# AIASSIST_BASE_URL=https://api.aiassist.net
# AIASSIST_API_KEY=

# ── Monetization (hosted instance only — self-host default is unlimited free) ──
# Limits activate when STRIPE_SECRET_KEY is set OR the limit is set explicitly.
# LINKS_FREE_PROFILE_LIMIT=1

# Pay-what-you-want (one time) via Stripe. Floor in cents (default 100 = $1).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# LINKS_PWYW_MIN_CENTS=100

# Hold-ITC door: threshold in whole ITC on the account address (default 100),
# checked against the Interchained ElectrumX fleet.
# LINKS_ITC_THRESHOLD=100
# ELECTRUMX_HOST=seed.interchained.org
# ELECTRUMX_PORT=50002
# ELECTRUMX_TLS=1

# ── Product mode ─────────────────────────────────────────────────────────────
# wallet (default) — interchained.org: seed-phrase accounts, ITC-native.
#                    No email anywhere.
# email            — ne-db.com: email/password/recovery. NO wallet anywhere —
#                    no seed phrases, no ITC door, no crypto vocabulary.
# One codebase, one env var, two products. There is deliberately no "both".
LINKS_AUTH_MODE=wallet

# ── Mail (REQUIRED when LINKS_AUTH_MODE=email) ──────────────────────────────
# Mail-in-a-Box: host = your box (e.g. box.ne-db.com), port 587 STARTTLS
# (SMTP_SECURE=0), user = the FULL mailbox address. PUBLIC_ORIGIN is also
# required in email mode — links inside emails are built from it.
# SMTP_HOST=box.ne-db.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=no-reply@ne-db.com
# SMTP_PASS=
# MAIL_FROM="NEDB Links <no-reply@ne-db.com>"
